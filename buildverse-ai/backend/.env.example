# Required — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — which Gemini model the agents use
GEMINI_MODEL=gemini-2.5-flash

# Optional — comma-separated origins allowed to call this API (Next.js dev server by default)
ALLOWED_ORIGINS=http://localhost:3000

# --- Optional MCP integrations (see app/mcp_tools.py) ---
# Leave blank to run without them — the Architect/Frontend agents work fine unassisted.

# GitHub's hosted remote MCP server (https://github.com/github/github-mcp-server)
GITHUB_MCP_TOKEN=

# Your own Documentation MCP server, if you stand one up (e.g. via mcp-server-fetch or a custom server)
DOCS_MCP_URL=

# Your own UI Inspiration MCP server, if you stand one up
UI_MCP_URL=
